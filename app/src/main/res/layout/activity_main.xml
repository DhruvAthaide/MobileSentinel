<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center">

    <EditText
        android:id="@+id/editTextText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:fontFamily="monospace"
        android:inputType="text"
        android:text="MOBILE SENTINEL"
        android:textAlignment="center"
        android:textColor="#FF1100"
        android:textSize="34sp"
        android:textStyle="bold"
        android:typeface="normal" />

    <Button
        android:id="@+id/btn_network_scanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Network Scanner" />

    <Button
        android:id="@+id/btn_vulnerability_scanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vulnerability Scanner" />

    <Button
        android:id="@+id/btn_traffic_sniffing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Traffic Sniffing" />

    <Button
        android:id="@+id/btn_ssh_client"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SSH Client" />

    <Button
        android:id="@+id/btn_permission_analyzer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Permission Analyzer" />

</LinearLayout>